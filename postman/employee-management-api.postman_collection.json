{
  "info": {
    "name": "Employee Management API",
    "description": "Postman collection for testing Employee Management System APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Employees",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/employees",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["employees"]
        }
      }
    },
    {
      "name": "Add Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@email.com\",\n  \"department\": \"IT\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/employees",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["employees"]
        }
      }
    },
    {
      "name": "Delete Employee",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/employees/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["employees", "1"]
        }
      }
    }
  ]
}
